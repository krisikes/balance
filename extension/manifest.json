{
    "manifest_version": 3,
    "name": "Balance",
    "version": "0.3",
    "description": "Detects pornographic content using URL and keyword analysis on a backend server.",
    "permissions": [
      "storage" 
    ],
    "host_permissions": [
      "http://127.0.0.1:5000/" 
    ],
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_end"
      }
    ],
    "action": {
      "default_popup": "popup.html",
      "default_title": "Balance",
      "default_icon": {
        "48": "icons/icon48.png",
      "128": "icons/icon128.png"
       }
    },
  
    "icons": {
      
       "48": "icons/icon48.png",
      "128": "icons/icon128.png"
     },
    "options_page": "options.html" 
  }